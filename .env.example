# ── Newsgroups Semantic Search — Environment Variables ────────────────────────
# Copy this file to .env and adjust values as needed.
# The app works with defaults — these are all optional overrides.

# Similarity threshold for semantic cache (0.0 - 1.0)
# Lower  = more cache hits, less precise
# Higher = fewer cache hits, more precise
# Default: 0.80
SIMILARITY_THRESHOLD=0.80

# Number of search results to return per query
# Default: 5
TOP_K_RESULTS=5

# Path to Qdrant index (relative to project root)
QDRANT_PATH=./embeddings/qdrant_index

# Path to saved models directory
MODELS_PATH=./models

# Uvicorn host and port
HOST=0.0.0.0
PORT=8000